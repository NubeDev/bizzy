    "prompts": [
      {
        "name": "content_review",
        "description": "Review marketing content for quality, tone, and accuracy",
        "arguments": [
          {
            "name": "content",
            "description": "The content to review",
            "required": true
          }
        ],
        "body": "Review the following marketing content for NubeIO:\n\n{{content}}\n\nCheck for:\n- Technical accuracy (IoT/BMS terminology)\n- Tone consistency (professional but approachable)\n- Clear value proposition\n- Call to action\n- Grammar and readability\n\nProvide specific suggestions for improvement."
      },
      {
        "name": "marketing_plan",
        "description": "Generate a marketing plan for a NubeIO product or feature",
        "arguments": [
          {
            "name": "product",
            "description": "The product or feature to market",
            "required": true
          },
          {
            "name": "audience",
            "description": "Target audience",
            "required": false
          }
        ],
        "body": "Create a marketing plan for **{{product}}**.\n\nTarget audience: {{audience}}\n\nInclude:\n1. Key messaging and value propositions\n2. Channel strategy (content, social, email, events)\n3. Timeline with milestones\n4. Success metrics and KPIs\n\nFocus on B2B IoT/building automation buyers. Keep it practical and actionable."
      }
