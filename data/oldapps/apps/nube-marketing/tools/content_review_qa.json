{
  "name": "content_review_qa",
  "description": "Guided content review — collects content and review preferences then generates feedback.",
  "toolClass": "read-only",
  "mode": "qa",
  "params": {
    "_submit": {
      "type": "boolean",
      "required": false,
      "description": "Set to true when submitting answers."
    },
    "content": {
      "type": "string",
      "required": false,
      "description": "The marketing content to review",
      "order": 1
    },
    "content_type": {
      "type": "string",
      "required": false,
      "description": "Type of content",
      "order": 2
    },
    "tone": {
      "type": "string",
      "required": false,
      "description": "Desired tone",
      "order": 3
    },
    "focus_areas": {
      "type": "string",
      "required": false,
      "description": "Comma-separated areas to focus the review on",
      "order": 4
    }
  }
}
